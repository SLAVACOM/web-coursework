        </mxCell>

        <mxCell id="u1" value="GET  /  — каталог инструментов" style="text;html=1;fontSize=10;align=left;spacingLeft=8;fillColor=#f9fff9;strokeColor=#c3e6c3;" vertex="1" parent="1">
