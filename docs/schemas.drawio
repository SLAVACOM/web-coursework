  <!-- ============================================================ -->
  <!-- Страница 1: Схема маршрутизации MVC                          -->
  <!-- ============================================================ -->
  <diagram id="mvc-flow" name="Рис. 3.1 Схема маршрутизации MVC">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="Рис. 3.1. Схема маршрутизации приложения (декомпозиция MVC)" style="text;html=1;align=center;fontStyle=1;fontSize=13;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="230" y="10" width="580" height="30" as="geometry"/>
        </mxCell>

        <!-- ── BROWSER ── -->
        <mxCell id="browser" value="&lt;b&gt;Браузер (Клиент)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;HTML · jQuery · JS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="50" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- ── ROUTER ── -->
        <mxCell id="router" value="&lt;b&gt;Маршрутизатор&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Express Router&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="185" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- ── AUTH MIDDLEWARE (diamond) ── -->
        <mxCell id="auth" value="&lt;b&gt;Auth Middleware&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Проверка сессии и роли&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="295" y="315" width="270" height="100" as="geometry"/>
        </mxCell>

        <!-- ── 403 ── -->
        <mxCell id="err" value="&lt;b&gt;403 Forbidden&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Доступ запрещён&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="330" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- ── CONTROLLER ── -->
        <mxCell id="ctrl" value="&lt;b&gt;Контроллер&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Обработка запроса&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="490" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- ── MODEL ── -->
        <mxCell id="model" value="&lt;b&gt;Модель&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SQL-абстракция данных&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="620" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- ── MYSQL ── -->
        <mxCell id="db" value="&lt;b&gt;MySQL 8.0&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;База данных&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="750" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ── EJS VIEW ── -->
        <mxCell id="view" value="&lt;b&gt;Представление (EJS)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Шаблон → HTML-страница&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="490" width="195" height="60" as="geometry"/>
        </mxCell>

        <!-- ── JSON ── -->
        <mxCell id="json" value="&lt;b&gt;JSON Ответ&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;AJAX / REST API&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="575" width="195" height="60" as="geometry"/>
        </mxCell>

        <!-- ════ ARROWS ════ -->

        <!-- Browser → Router -->
        <mxCell id="a1" value="HTTP Request (GET/POST)" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="browser" target="router" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Router → Auth -->
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="router" target="auth" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Auth → 403 (denied) -->
        <mxCell id="a3" value="нет прав" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="auth" target="err" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Auth → Controller (allowed) -->
        <mxCell id="a4" value="доступ разрешён" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="auth" target="ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Controller → Model -->
        <mxCell id="a5" value="вызов модели" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="ctrl" target="model" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Model → MySQL -->
        <mxCell id="a6" value="pool.execute()" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="model" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- MySQL → Model (return, right side) -->
        <mxCell id="a7" value="данные" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=1;entryY=1;" edge="1" source="db" target="model" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="790"/>
              <mxPoint x="580" y="650"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Model → Controller (return, left side) -->
        <mxCell id="a8" value="результат" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=1;" edge="1" source="model" target="ctrl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="650"/>
              <mxPoint x="270" y="550"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Controller → View -->
        <mxCell id="a9" value="res.render()" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" source="ctrl" target="view" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Controller → JSON -->
        <mxCell id="a10" value="res.json()" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.7;entryX=0;entryY=0.5;" edge="1" source="ctrl" target="json" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- View → Browser (HTML response) -->
        <mxCell id="a11" value="HTML ответ" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;entryX=1;entryY=0.3;curved=1;" edge="1" source="view" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="737" y="90"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- JSON → Browser (JSON response) -->
        <mxCell id="a12" value="JSON ответ" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=1;entryY=0.7;curved=1;" edge="1" source="json" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="605"/>
              <mxPoint x="900" y="120"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ============================================================ -->
  <!-- Страница 2: Структурная схема по ролям                       -->
  <!-- ============================================================ -->
  <diagram id="roles" name="Рис. 3.2 Структурная схема ролей">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t2" value="Рис. 3.2. Структурная схема доступа к маршрутам по ролям" style="text;html=1;align=center;fontStyle=1;fontSize=13;strokeColor=none;fillColor=none;" vertex="1" parent="1">
