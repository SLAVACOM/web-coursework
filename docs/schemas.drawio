        <mxCell id="u3" value="GET  /api/tools  — поиск (AJAX)" style="text;html=1;fontSize=10;align=left;spacingLeft=8;fillColor=#f9fff9;strokeColor=#c3e6c3;" vertex="1" parent="1">
          <mxGeometry x="20" y="180" width="270" height="22" as="geometry"/>
