        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!--   COLUMN 1 — user                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="h_user" value="👤  Пользователь (user)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
