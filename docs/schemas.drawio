        <!-- section label -->
        <mxCell id="s_u1" value="Общедоступные маршруты" style="text;html=1;fontStyle=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;align=center;" vertex="1" parent="1">
