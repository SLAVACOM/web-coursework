  <diagram id="ad" name="3. Панель администратора">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- HEADER -->
        <mxCell id="hdr" value="&lt;font style=&#39;font-size:20px;font-weight:bold&#39;&gt;👨‍💼  Панель администратора (admin)&lt;/font&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;opacity:0.85&#39;&gt;Инвентарь  ·  Категории  ·  Заявки  ·  Добавить  ·  Аналитика  ·  Пользователи  ·  Выйти&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dc2626;strokeColor=#7f1d1d;fontColor=#ffffff;arcSize=5;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="195" y="20" width="590" height="65" as="geometry" />
        </mxCell>
        <!-- ── SECTION HEADERS ── -->
        <mxCell id="s1" value="&lt;b&gt;📦 Права кладовщика&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;(полностью унаследованы)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#991b1b;strokeColor=#7f1d1d;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="10" y="150" width="295" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;📊 Панель аналитики&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET /admin&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#991b1b;strokeColor=#7f1d1d;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="150" width="315" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;👥 Управление пользователями&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET /admin/users&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#991b1b;strokeColor=#7f1d1d;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="150" width="325" height="45" as="geometry" />
        </mxCell>
        <!-- ── FEATURE BOXES ── -->
        <mxCell id="f1" value="📋 Просмотр каталога · поиск · фильтры&lt;br/&gt;➕ Создание и ✏️ редактирование инструментов&lt;br/&gt;🖼️ Управление фотографиями&lt;br/&gt;🗂️ Управление категориями&lt;br/&gt;📥 Обработка всех заявок системы" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fff1f2;strokeColor=#fca5a5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="220" width="295" height="132" as="geometry" />
