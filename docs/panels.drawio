        <mxCell id="f4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=10;" value="🏷️ Логин · Роль (бейдж-индикатор)&lt;br/&gt;✏️ Редактирование учётных данных&lt;br/&gt;🖼️ Загрузка фото профиля (multer)&lt;br/&gt;💾 POST /profile/update" vertex="1">
