        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b45309;strokeWidth=1.5;endArrow=block;endFill=1;endSize=6;" edge="1" source="r1s2" target="r1f2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b45309;strokeWidth=1.5;endArrow=block;endFill=1;endSize=6;" edge="1" source="r1s3" target="r1f3" parent="1">
          <mxGeometry relative="1" as="geometry" />
