  <diagram id="sk" name="2. Панель кладовщика">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- HEADER -->
        <mxCell id="hdr" value="&lt;font style=&#39;font-size:20px;font-weight:bold&#39;&gt;📦  Панель кладовщика (storekeeper)&lt;/font&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;opacity:0.85&#39;&gt;Инвентарь  ·  Категории  ·  Заявки  ·  Добавить  ·  Профиль  ·  Выйти&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d97706;strokeColor=#92400e;fontColor=#ffffff;arcSize=5;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="235" y="20" width="510" height="65" as="geometry" />
        </mxCell>
        <!-- ── ROW 1 SECTION HEADERS ── -->
        <mxCell id="r1s1" value="&lt;b&gt;📋 Каталог  +  карточки&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET /&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b45309;strokeColor=#92400e;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="10" y="150" width="300" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r1s2" value="&lt;b&gt;🔍 Страница инструмента&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET /tools/:id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b45309;strokeColor=#92400e;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="325" y="150" width="300" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r1s3" value="&lt;b&gt;➕ Создание  /  ✏️ Редактирование&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET+POST /tools/new  ·  /tools/:id/edit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b45309;strokeColor=#92400e;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="150" width="340" height="45" as="geometry" />
        </mxCell>
        <!-- ── ROW 1 FEATURE BOXES ── -->
        <mxCell id="r1f1" value="🔍 Поиск + все фильтры (как у пользователя)&lt;br/&gt;✏️ Кнопка «Изменить» на каждой карточке&lt;br/&gt;👁️ Кнопка «Просмотр» на каждой карточке&lt;br/&gt;📄 Пагинация и сортировка" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fffbeb;strokeColor=#fcd34d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="220" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="r1f2" value="🖼️ Галерея + drag-drop порядка миниатюр&lt;br/&gt;✕ Удаление отдельного фото (POST)&lt;br/&gt;📊 Все характеристики · Доступно/Всего&lt;br/&gt;✏️ Кнопка «Редактировать» → /tools/:id/edit&lt;br/&gt;🗑️ Кнопка «Удалить инструмент»&lt;br/&gt;POST /tools/:id/delete" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fffbeb;strokeColor=#fcd34d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="325" y="220" width="300" height="155" as="geometry" />
        </mxCell>
        <mxCell id="r1f3" value="🏷️ Название инструмента (обязательное)&lt;br/&gt;🗂️ Категория (select из справочника)&lt;br/&gt;📦 Количество  ·  ⭐ Состояние  ·  💰 Цена&lt;br/&gt;📅 Дата закупки  ·  📝 Описание&lt;br/&gt;🖼️ Загрузка до 10 фото (JPG / PNG / WebP)&lt;br/&gt;✕ Удаление фото при редактировании&lt;br/&gt;POST /tools/:id/update  ·  POST /tools" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fffbeb;strokeColor=#fcd34d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="220" width="340" height="180" as="geometry" />
        </mxCell>
        <!-- ── ROW 2 SECTION HEADERS ── -->
        <mxCell id="r2s1" value="&lt;b&gt;🗂️ Управление категориями&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET+POST /categories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b45309;strokeColor=#92400e;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="10" y="420" width="300" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r2s2" value="&lt;b&gt;📥 Заявки на выдачу (все пользователи)&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;GET /bookings  ·  POST /bookings/:id/status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b45309;strokeColor=#92400e;fontColor=#fff;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="325" y="420" width="655" height="45" as="geometry" />
        </mxCell>
        <!-- ── ROW 2 FEATURE BOXES ── -->
        <mxCell id="r2f1" value="📋 Список категорий (с кол-вом инструментов)&lt;br/&gt;➕ Создать  POST /categories&lt;br/&gt;🗑️ Удалить  POST /categories/:id/delete" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fffbeb;strokeColor=#fcd34d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="490" width="300" height="88" as="geometry" />
        </mxCell>
        <mxCell id="r2f2" value="🏷️ Вкладки: Все / Ожидает / Одобрено / Выдано / Возвращено / Отклонено&lt;br/&gt;📋 Таблица: # · Инструмент · Пользователь · Кол-во · Статус · Дата&lt;br/&gt;✅ pending → approved  (Одобрить)&lt;br/&gt;❌ pending → rejected  (Отклонить)&lt;br/&gt;📦 approved → issued  (Выдать инструмент)&lt;br/&gt;↩️ issued → returned  (Принять возврат)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#fffbeb;strokeColor=#fcd34d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="325" y="490" width="655" height="155" as="geometry" />
        </mxCell>
        <!-- ── EDGES: header → row1 sections ── -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2;endArrow=block;endFill=1;endSize=7;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hdr" target="r1s1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2;endArrow=block;endFill=1;endSize=7;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hdr" target="r1s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2;endArrow=block;endFill=1;endSize=7;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hdr" target="r1s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ── EDGES: header → row2 sections ── -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2;endArrow=block;endFill=1;endSize=7;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hdr" target="r2s1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2;endArrow=block;endFill=1;endSize=7;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hdr" target="r2s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ── EDGES: sections → features ── -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b45309;strokeWidth=1.5;endArrow=block;endFill=1;endSize=6;" edge="1" source="r1s1" target="r1f1" parent="1">
          <mxGeometry relative="1" as="geometry" />
