<%- include('../partials/header') %>

<div class="container">
  <div class="page-title">
    <h1>Заявки на выдачу</h1>
  </div>

  <nav class="seg-tabs">
  <a href="/bookings" class="seg-tab <%= filterStatus==='' ? 'active' : '' %>">Все</a>
  <a href="/bookings?status=pending"  class="seg-tab <%= filterStatus==='pending'  ? 'active' : '' %>">Ожидает</a>
  <a href="/bookings?status=approved" class="seg-tab <%= filterStatus==='approved' ? 'active' : '' %>">Одобрено</a>
  <a href="/bookings?status=issued"   class="seg-tab <%= filterStatus==='issued'   ? 'active' : '' %>">Выдано</a>
  <a href="/bookings?status=returned" class="seg-tab <%= filterStatus==='returned' ? 'active' : '' %>">Возвращено</a>
  <a href="/bookings?status=rejected" class="seg-tab <%= filterStatus==='rejected' ? 'active' : '' %>">Отклонено</a>
</nav>

<% if (bookings.length === 0) { %>
  <p class="empty">
    <span class="empty-icon">📋</span>
    Заявок нет
  </p>
<% } else { %>
<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>#</th>
        <th>Инструмент</th>
        <th>Пользователь</th>
        <th>Кол-во</th>
        <th>Статус</th>
        <th>Дата</th>
        <th>Примечание</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% bookings.forEach(b => { %>
      <tr>
        <td><%= b.id %></td>
        <td>
          <div class="booking-tool">
            <% if (b.tool_image) { %>
              <img src="/uploads/<%= b.tool_image %>" class="booking-thumb" alt="">
            <% } %>
            <a href="/tools/<%= b.tool_id %>"><%= b.tool_name %></a>
          </div>
        </td>
        <td><%= b.username %></td>
        <td><%= b.quantity %> шт.</td>
        <td><span class="status-badge status-badge--<%= b.status %>"><%= statusLabels[b.status] %></span></td>
        <td><%= new Date(b.created_at).toLocaleDateString('ru-RU') %></td>
        <td class="note-cell"><%= b.note || '—' %></td>
        <td>
          <div class="action-group">
            <% if (b.status === 'pending') { %>
              <form action="/bookings/<%= b.id %>/status" method="POST">
                <input type="hidden" name="status" value="approved">
                <button class="btn btn--sm btn--primary">Одобрить</button>
              </form>
              <form action="/bookings/<%= b.id %>/status" method="POST">
                <input type="hidden" name="status" value="rejected">
                <button class="btn btn--sm btn--danger">Отклонить</button>
              </form>
            <% } else if (b.status === 'approved') { %>
              <form action="/bookings/<%= b.id %>/status" method="POST">
                <input type="hidden" name="status" value="issued">
                <button class="btn btn--sm btn--primary">Выдать</button>
              </form>
              <form action="/bookings/<%= b.id %>/status" method="POST">
                <input type="hidden" name="status" value="rejected">
                <button class="btn btn--sm btn--danger">Отклонить</button>
              </form>
            <% } else if (b.status === 'issued') { %>
              <form action="/bookings/<%= b.id %>/status" method="POST">
                <input type="hidden" name="status" value="returned">
                <button class="btn btn--sm">Возврат</button>
              </form>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
</div>

<%- include('../partials/footer') %>
