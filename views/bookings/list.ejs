<%- include('../partials/header') %>

<%
  function qs(overrides) {
    const base = {
      status: filterStatus || '',
      search: search || '',
      sort: sort || '',
      limit: limit || '',
      page: page || 1,
    };
    const merged = Object.assign({}, base, overrides);
    const parts = [];
    for (const k in merged) {
      const v = merged[k];
      if (v !== '' && v !== null && v !== undefined) {
        parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(v));
      }
    }
    return '?' + parts.join('&');
  }
%>

<div class="container">
  <div class="page-title">
    <h1>Заявки на выдачу</h1>
  </div>

  <nav class="seg-tabs">
    <a href="<%= qs({ status: '', page: 1 }) %>" class="seg-tab <%= filterStatus==='' ? 'active' : '' %>">Все</a>
    <a href="<%= qs({ status: 'pending',  page: 1 }) %>" class="seg-tab <%= filterStatus==='pending'  ? 'active' : '' %>">Ожидает</a>
    <a href="<%= qs({ status: 'approved', page: 1 }) %>" class="seg-tab <%= filterStatus==='approved' ? 'active' : '' %>">Одобрено</a>
    <a href="<%= qs({ status: 'issued',   page: 1 }) %>" class="seg-tab <%= filterStatus==='issued'   ? 'active' : '' %>">Выдано</a>
    <a href="<%= qs({ status: 'returned', page: 1 }) %>" class="seg-tab <%= filterStatus==='returned' ? 'active' : '' %>">Возвращено</a>
    <a href="<%= qs({ status: 'rejected', page: 1 }) %>" class="seg-tab <%= filterStatus==='rejected' ? 'active' : '' %>">Отклонено</a>
  </nav>

  <div class="filters">
    <input id="b-search" type="text" placeholder="🔍 Поиск по пользователю, инструменту или примечанию…" value="<%= search %>">
    <select id="b-sort">
      <option value="date_desc" <%= sort === 'date_desc' ? 'selected' : '' %>>Сначала новые</option>
      <option value="date_asc"  <%= sort === 'date_asc'  ? 'selected' : '' %>>Сначала старые</option>
      <option value="status"    <%= sort === 'status'    ? 'selected' : '' %>>По статусу</option>
      <option value="user"      <%= sort === 'user'      ? 'selected' : '' %>>По пользователю</option>
      <option value="tool"      <%= sort === 'tool'      ? 'selected' : '' %>>По инструменту</option>
      <option value="quantity"  <%= sort === 'quantity'  ? 'selected' : '' %>>По количеству</option>
    </select>
    <select id="b-limit">
      <option value="10"  <%= String(limit) === '10'  ? 'selected' : '' %>>10 на странице</option>
      <option value="25"  <%= String(limit) === '25'  ? 'selected' : '' %>>25 на странице</option>
      <option value="50"  <%= String(limit) === '50'  ? 'selected' : '' %>>50 на странице</option>
      <option value="100" <%= String(limit) === '100' ? 'selected' : '' %>>100 на странице</option>
    </select>
  </div>

  <% if (total > 0) { %>
    <div class="pagination-info">
      <span>Показано <strong><%= (page - 1) * limit + 1 %></strong>–<strong><%= Math.min(page * limit, total) %></strong> из <strong><%= total %></strong></span>
    </div>
  <% } %>

  <% if (bookings.length === 0) { %>
    <p class="empty">
      <span class="empty-icon">📋</span>
      <% if (search || filterStatus) { %>
        По заданным фильтрам ничего не найдено
      <% } else { %>
        Заявок нет
      <% } %>
    </p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Инструмент</th>
            <th>Пользователь</th>
            <th>Кол-во</th>
            <th>Статус</th>
            <th>Дата</th>
            <th>Примечание</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(b => { %>
            <tr>
              <td><%= b.id %></td>
              <td>
                <div class="booking-tool">
                  <% if (b.tool_image) { %>
                    <img src="/uploads/<%= b.tool_image %>" class="booking-thumb" alt="">
                  <% } %>
                  <a href="/tools/<%= b.tool_id %>"><%= b.tool_name %></a>
                </div>
              </td>
              <td><%= b.username %></td>
              <td><%= b.quantity %> шт.</td>
              <td><span class="status-badge status-badge--<%= b.status %>"><%= statusLabels[b.status] %></span></td>
              <td><%= new Date(b.created_at).toLocaleDateString('ru-RU') %></td>
              <td class="note-cell"><%= b.note || '—' %></td>
              <td>
                <div class="action-group">
                  <% if (b.status === 'pending') { %>
                    <form action="/bookings/<%= b.id %>/status" method="POST">
                      <input type="hidden" name="status" value="approved">
                      <button class="btn btn--sm btn--primary">Одобрить</button>
                    </form>
                    <form action="/bookings/<%= b.id %>/status" method="POST">
                      <input type="hidden" name="status" value="rejected">
                      <button class="btn btn--sm btn--danger">Отклонить</button>
                    </form>
                  <% } else if (b.status === 'approved') { %>
                    <form action="/bookings/<%= b.id %>/status" method="POST">
                      <input type="hidden" name="status" value="issued">
                      <button class="btn btn--sm btn--primary">Выдать</button>
                    </form>
                    <form action="/bookings/<%= b.id %>/status" method="POST">
                      <input type="hidden" name="status" value="rejected">
                      <button class="btn btn--sm btn--danger">Отклонить</button>
                    </form>
                  <% } else if (b.status === 'issued') { %>
                    <form action="/bookings/<%= b.id %>/status" method="POST">
                      <input type="hidden" name="status" value="returned">
                      <button class="btn btn--sm">Возврат</button>
                    </form>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="<%= qs({ page: 1 }) %>" class="pagination__btn pagination__btn--first">« Первая</a>
          <a href="<%= qs({ page: page - 1 }) %>" class="pagination__btn pagination__btn--prev">‹ Предыдущая</a>
        <% } %>

        <div class="pagination__pages">
          <%
            const maxVisible = 5;
            let start = Math.max(1, page - Math.floor(maxVisible / 2));
            let end = Math.min(totalPages, start + maxVisible - 1);
            if (end - start + 1 < maxVisible) start = Math.max(1, end - maxVisible + 1);
          %>

          <% if (start > 1) { %>
            <a href="<%= qs({ page: 1 }) %>" class="pagination__page">1</a>
            <% if (start > 2) { %><span class="pagination__dots">…</span><% } %>
          <% } %>

          <% for (let i = start; i <= end; i++) { %>
            <% if (i === page) { %>
              <span class="pagination__page pagination__page--active"><%= i %></span>
            <% } else { %>
              <a href="<%= qs({ page: i }) %>" class="pagination__page"><%= i %></a>
            <% } %>
          <% } %>

          <% if (end < totalPages) { %>
            <% if (end < totalPages - 1) { %><span class="pagination__dots">…</span><% } %>
            <a href="<%= qs({ page: totalPages }) %>" class="pagination__page"><%= totalPages %></a>
          <% } %>
        </div>

        <% if (page < totalPages) { %>
          <a href="<%= qs({ page: page + 1 }) %>" class="pagination__btn pagination__btn--next">Следующая ›</a>
          <a href="<%= qs({ page: totalPages }) %>" class="pagination__btn pagination__btn--last">Последняя »</a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>

<script>
  (function () {
    var currentParams = new URLSearchParams(window.location.search);

    function apply(overrides) {
      var params = new URLSearchParams(currentParams.toString());
      Object.keys(overrides).forEach(function (k) {
        var v = overrides[k];
        if (v === '' || v === null || v === undefined) {
          params.delete(k);
        } else {
          params.set(k, v);
        }
      });
      params.set('page', '1');
      window.location.href = '?' + params.toString();
    }

    var searchInput = document.getElementById('b-search');
    var sortSelect  = document.getElementById('b-sort');
    var limitSelect = document.getElementById('b-limit');

    var debounceTimer;
    searchInput.addEventListener('input', function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () {
        apply({ search: searchInput.value.trim() });
      }, 500);
    });
    searchInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        clearTimeout(debounceTimer);
        apply({ search: searchInput.value.trim() });
      }
    });

    sortSelect.addEventListener('change',  function () { apply({ sort:  sortSelect.value  }); });
    limitSelect.addEventListener('change', function () { apply({ limit: limitSelect.value }); });
  })();
</script>

<%- include('../partials/footer') %>
