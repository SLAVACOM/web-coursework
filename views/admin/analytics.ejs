<%- include('../partials/header') %>

<div class="analytics-hero">
  <div class="analytics-hero__content">
    <h1 class="analytics-hero__title">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -5px; margin-right: 8px;">
        <line x1="18" y1="20" x2="18" y2="10"/>
        <line x1="12" y1="20" x2="12" y2="4"/>
        <line x1="6" y1="20" x2="6" y2="14"/>
      </svg>
      Панель аналитики
    </h1>
    <p class="analytics-hero__subtitle">Обзор инвентаря, активности и пользователей в реальном времени</p>
  </div>
  <div class="analytics-hero__date">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    <%= new Date().toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }) %>
  </div>
</div>

<!-- KPI карточки -->
<div class="kpi-grid">
  <div class="kpi-card kpi-card--green">
    <div class="kpi-card__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      </svg>
    </div>
    <div class="kpi-card__content">
      <div class="kpi-card__label">Всего позиций</div>
      <div class="kpi-card__value"><%= inventoryValue.total_tools || 0 %></div>
      <div class="kpi-card__hint">уникальных инструментов</div>
    </div>
    <div class="kpi-card__sparkle"></div>
  </div>

  <div class="kpi-card kpi-card--blue">
    <div class="kpi-card__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3h18v18H3z"/>
        <path d="M9 9h6v6H9z"/>
      </svg>
    </div>
    <div class="kpi-card__content">
      <div class="kpi-card__label">Общее количество</div>
      <div class="kpi-card__value"><%= inventoryValue.total_quantity || 0 %></div>
      <div class="kpi-card__hint">единиц на складе</div>
    </div>
    <div class="kpi-card__sparkle"></div>
  </div>

  <div class="kpi-card kpi-card--amber">
    <div class="kpi-card__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="1" x2="12" y2="23"/>
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
    </div>
    <div class="kpi-card__content">
      <div class="kpi-card__label">Стоимость</div>
      <div class="kpi-card__value"><%= new Intl.NumberFormat('ru-RU', { maximumFractionDigits: 0 }).format(Math.round(inventoryValue.total_value || 0)) %> ₽</div>
      <div class="kpi-card__hint">общая оценка</div>
    </div>
    <div class="kpi-card__sparkle"></div>
  </div>

  <div class="kpi-card kpi-card--red">
    <div class="kpi-card__icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </div>
    <div class="kpi-card__content">
      <div class="kpi-card__label">Низкий запас</div>
      <div class="kpi-card__value"><%= lowStockTools.length %></div>
      <div class="kpi-card__hint">требуют пополнения</div>
    </div>
    <div class="kpi-card__sparkle"></div>
  </div>
</div>

<!-- Главный график активности -->
<div class="chart-card chart-card--featured">
  <div class="chart-card__header">
    <div>
      <h2 class="chart-card__title">📈 Активность бронирований</h2>
      <div class="chart-card__subtitle">Динамика заявок по месяцам</div>
    </div>
  </div>
  <div class="chart-card__body" style="height: 320px;">
    <canvas id="activityChart"></canvas>
  </div>
</div>

<!-- Сетка диаграмм -->
<div class="charts-row">
  <div class="chart-card">
    <div class="chart-card__header">
      <h2 class="chart-card__title">🗂️ По категориям</h2>
      <div class="chart-card__subtitle">Распределение позиций</div>
    </div>
    <div class="chart-card__body" style="height: 280px;">
      <canvas id="categoryChart"></canvas>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-card__header">
      <h2 class="chart-card__title">⭐ По состоянию</h2>
      <div class="chart-card__subtitle">Качество инвентаря</div>
    </div>
    <div class="chart-card__body" style="height: 280px;">
      <canvas id="conditionChart"></canvas>
    </div>
  </div>
</div>

<div class="charts-row">
  <div class="chart-card">
    <div class="chart-card__header">
      <h2 class="chart-card__title">👥 Пользователи</h2>
      <div class="chart-card__subtitle">По ролям в системе</div>
    </div>
    <div class="chart-card__body" style="height: 280px;">
      <canvas id="userChart"></canvas>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-card__header">
      <h2 class="chart-card__title">📋 Статусы заявок</h2>
      <div class="chart-card__subtitle">Текущее распределение</div>
    </div>
    <div class="chart-card__body" style="height: 280px;">
      <canvas id="bookingChart"></canvas>
    </div>
  </div>
</div>

<!-- Топ инструментов -->
<div class="chart-card">
  <div class="chart-card__header">
    <h2 class="chart-card__title">🏆 Самые популярные инструменты</h2>
    <div class="chart-card__subtitle">Топ-10 по количеству бронирований</div>
  </div>
  <div class="chart-card__body" style="height: 380px;">
    <canvas id="popularChart"></canvas>
  </div>
</div>

<!-- Инструменты с низким запасом -->
<% if (lowStockTools.length > 0) { %>
<div class="low-stock-card">
  <div class="low-stock-card__header">
    <h2>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -3px; color: var(--amber); margin-right: 6px;">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      Требуют пополнения
    </h2>
    <span class="low-stock-card__badge"><%= lowStockTools.length %></span>
  </div>
  <div class="low-stock-list">
    <% lowStockTools.forEach(tool => { %>
      <a href="/tools/<%= tool.id %>" class="low-stock-item">
        <div class="low-stock-item__qty <%= tool.quantity === 0 ? 'low-stock-item__qty--empty' : '' %>">
          <%= tool.quantity %>
        </div>
        <div class="low-stock-item__info">
          <div class="low-stock-item__name"><%= tool.name %></div>
          <div class="low-stock-item__category"><%= tool.category_name || 'Без категории' %></div>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="low-stock-item__arrow">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    <% }) %>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
<script>
  // Chart.js глобальная настройка
  Chart.defaults.font.family = "'Inter', system-ui, -apple-system, sans-serif";
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#6b7280';
  Chart.defaults.plugins.legend.labels.usePointStyle = true;
  Chart.defaults.plugins.legend.labels.padding = 16;
  Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(15, 23, 42, 0.92)';
  Chart.defaults.plugins.tooltip.titleColor = '#fff';
  Chart.defaults.plugins.tooltip.bodyColor = '#e5e7eb';
  Chart.defaults.plugins.tooltip.padding = 12;
  Chart.defaults.plugins.tooltip.cornerRadius = 8;
  Chart.defaults.plugins.tooltip.titleFont = { weight: 'bold', size: 13 };
  Chart.defaults.plugins.tooltip.boxPadding = 6;

  const palette = {
    green:  '#16a34a',
    green2: '#22c55e',
    blue:   '#3b82f6',
    blue2:  '#60a5fa',
    amber:  '#f59e0b',
    amber2: '#fbbf24',
    red:    '#ef4444',
    purple: '#8b5cf6',
    pink:   '#ec4899',
    cyan:   '#06b6d4',
    gray:   '#94a3b8',
  };
  const colorList = ['#16a34a', '#3b82f6', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4', '#ef4444', '#84cc16', '#f97316', '#6366f1'];

  function makeGradient(ctx, color, alpha1 = 0.35, alpha2 = 0.02) {
    const gradient = ctx.createLinearGradient(0, 0, 0, 320);
    gradient.addColorStop(0, color + Math.round(alpha1 * 255).toString(16).padStart(2, '0'));
    gradient.addColorStop(1, color + Math.round(alpha2 * 255).toString(16).padStart(2, '0'));
    return gradient;
  }

  // Активность по месяцам — line chart с градиентом
  const monthlyActivityData = <%- monthlyActivity %>;
  const activityCanvas = document.getElementById('activityChart');
  const activityCtx = activityCanvas.getContext('2d');
  new Chart(activityCtx, {
    type: 'line',
    data: {
      labels: monthlyActivityData.map(d => {
        const [y, m] = d.month.split('-');
        const months = ['Янв', 'Фев', 'Мар', 'Апр', 'Май', 'Июн', 'Июл', 'Авг', 'Сен', 'Окт', 'Ноя', 'Дек'];
        return months[parseInt(m) - 1] + ' ' + y.slice(2);
      }),
      datasets: [{
        label: 'Заявок',
        data: monthlyActivityData.map(d => d.bookings_count),
        borderColor: palette.green,
        backgroundColor: makeGradient(activityCtx, palette.green, 0.35, 0.0),
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointRadius: 6,
        pointHoverRadius: 9,
        pointBackgroundColor: '#fff',
        pointBorderColor: palette.green,
        pointBorderWidth: 3,
        pointHoverBorderWidth: 4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(15, 23, 42, 0.06)', drawBorder: false },
          ticks: { padding: 10 }
        },
        x: { grid: { display: false }, ticks: { padding: 8 } }
      },
      interaction: { intersect: false, mode: 'index' }
    }
  });

  // По категориям — bar chart
  const toolsByCategoryData = <%- toolsByCategory %>;
  const categoryCtx = document.getElementById('categoryChart').getContext('2d');
  new Chart(categoryCtx, {
    type: 'bar',
    data: {
      labels: toolsByCategoryData.map(d => d.name),
      datasets: [{
        label: 'Инструментов',
        data: toolsByCategoryData.map(d => d.count),
        backgroundColor: toolsByCategoryData.map((_, i) => colorList[i % colorList.length] + 'cc'),
        borderColor: toolsByCategoryData.map((_, i) => colorList[i % colorList.length]),
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(15, 23, 42, 0.06)', drawBorder: false },
          ticks: { padding: 10 }
        },
        x: { grid: { display: false }, ticks: { padding: 6 } }
      }
    }
  });

  // По состоянию — doughnut
  const toolsByConditionData = <%- toolsByCondition %>;
  const conditionColorMap = {
    'отличное': '#16a34a',
    'хорошее': '#22c55e',
    'удовлетворительное': '#f59e0b',
    'плохое': '#ef4444',
  };
  const conditionCtx = document.getElementById('conditionChart').getContext('2d');
  new Chart(conditionCtx, {
    type: 'doughnut',
    data: {
      labels: toolsByConditionData.map(d => d.condition),
      datasets: [{
        data: toolsByConditionData.map(d => d.count),
        backgroundColor: toolsByConditionData.map(d => conditionColorMap[d.condition] || palette.gray),
        borderColor: '#fff',
        borderWidth: 4,
        hoverOffset: 14,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '65%',
      plugins: {
        legend: { position: 'bottom', labels: { padding: 14, pointStyle: 'circle' } }
      }
    }
  });

  // Пользователи — pie
  const userStatsData = <%- userStats %>;
  const roleLabels = { 'admin': 'Администраторы', 'storekeeper': 'Кладовщики', 'user': 'Пользователи' };
  const roleColors = { 'admin': '#8b5cf6', 'storekeeper': '#3b82f6', 'user': '#94a3b8' };
  const userCtx = document.getElementById('userChart').getContext('2d');
  new Chart(userCtx, {
    type: 'doughnut',
    data: {
      labels: userStatsData.map(d => roleLabels[d.role] || d.role),
      datasets: [{
        data: userStatsData.map(d => d.count),
        backgroundColor: userStatsData.map(d => roleColors[d.role] || palette.gray),
        borderColor: '#fff',
        borderWidth: 4,
        hoverOffset: 14,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '65%',
      plugins: {
        legend: { position: 'bottom', labels: { padding: 14, pointStyle: 'circle' } }
      }
    }
  });

  // Статусы бронирований — bar
  const bookingStatsData = <%- bookingStats %>;
  const statusLabels = {
    'pending': 'Ожидает', 'approved': 'Одобрено', 'issued': 'Выдано',
    'returned': 'Возвращено', 'rejected': 'Отклонено'
  };
  const statusColors = {
    'pending': '#f59e0b', 'approved': '#3b82f6', 'issued': '#16a34a',
    'returned': '#94a3b8', 'rejected': '#ef4444'
  };
  const bookingCtx = document.getElementById('bookingChart').getContext('2d');
  new Chart(bookingCtx, {
    type: 'bar',
    data: {
      labels: bookingStatsData.map(d => statusLabels[d.status] || d.status),
      datasets: [{
        label: 'Заявок',
        data: bookingStatsData.map(d => d.count),
        backgroundColor: bookingStatsData.map(d => (statusColors[d.status] || palette.gray) + 'cc'),
        borderColor: bookingStatsData.map(d => statusColors[d.status] || palette.gray),
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(15, 23, 42, 0.06)', drawBorder: false },
          ticks: { padding: 10 }
        },
        x: { grid: { display: false }, ticks: { padding: 6 } }
      }
    }
  });

  // Популярные инструменты — горизонтальный bar
  const popularToolsData = <%- popularTools %>;
  const popularCtx = document.getElementById('popularChart').getContext('2d');
  new Chart(popularCtx, {
    type: 'bar',
    data: {
      labels: popularToolsData.map(d => d.name),
      datasets: [{
        label: 'Бронирований',
        data: popularToolsData.map(d => d.booking_count),
        backgroundColor: makeGradient(popularCtx, palette.purple, 0.85, 0.5),
        borderColor: palette.purple,
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          beginAtZero: true,
          grid: { color: 'rgba(15, 23, 42, 0.06)', drawBorder: false },
          ticks: { padding: 10 }
        },
        y: { grid: { display: false }, ticks: { padding: 6 } }
      }
    }
  });
</script>
