<%- include('../partials/header') %>

<div class="page-title">
  <h1>Управление пользователями</h1>
</div>

<% if (flash.error) { %>
  <div class="alert alert--error"><%= flash.error %></div>
<% } %>
<% if (flash.success) { %>
  <div class="alert alert--success"><%= flash.success %></div>
<% } %>

<div class="two-col">
  <div>
    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Имя пользователя</th>
          <th>Роль</th>
          <th>Создан</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% allUsers.forEach(u => { %>
          <tr>
            <td><%= u.id %></td>
            <td>
              <%= u.username %>
              <% if (u.id === user.id) { %>
                <span class="self-badge">(вы)</span>
              <% } %>
            </td>
            <td>
              <% if (u.id === user.id) { %>
                <span class="role-badge role-badge--<%= u.role %>"><%= roleLabels[u.role] %></span>
              <% } else { %>
                <form action="/admin/users/<%= u.id %>/role" method="POST" class="inline-form">
                  <select name="role" onchange="this.form.submit()">
                    <% roles.forEach(r => { %>
                      <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= roleLabels[r] %></option>
                    <% }) %>
                  </select>
                </form>
              <% } %>
            </td>
            <td><%= new Date(u.created_at).toLocaleDateString('ru-RU') %></td>
            <td>
              <% if (u.id !== user.id) { %>
                <form action="/admin/users/<%= u.id %>/delete" method="POST"
                      onsubmit="return confirm('Удалить пользователя «<%= u.username %>»?')">
                  <button type="submit" class="btn btn--sm btn--danger">Удалить</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="sidebar-panel">
    <div class="sidebar-panel__title">Добавить пользователя</div>
    <div class="sidebar-panel__body">
      <form action="/admin/users" method="POST">
        <div class="form-group">
          <label for="username">Имя пользователя *</label>
          <input id="username" name="username" type="text" required placeholder="Логин">
        </div>
        <div class="form-group">
          <label for="password">Пароль *</label>
          <input id="password" name="password" type="password" required placeholder="Минимум 6 символов" minlength="6">
        </div>
        <div class="form-group">
          <label for="role">Роль *</label>
          <select id="role" name="role" required>
            <% roles.forEach(r => { %>
              <option value="<%= r %>"><%= roleLabels[r] %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn--primary btn--full">Создать</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
