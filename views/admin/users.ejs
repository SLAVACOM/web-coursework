<%- include('../partials/header') %>

<div class="page-title">
  <h1>Пользователи</h1>
</div>

<% if (flash.error) { %>
  <div class="alert alert--error">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <%= flash.error %>
  </div>
<% } %>
<% if (flash.success) { %>
  <div class="alert alert--success">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <%= flash.success %>
  </div>
<% } %>

<!-- Статистика по ролям -->
<%
  const counts = { admin: 0, storekeeper: 0, user: 0 };
  allUsers.forEach(u => { counts[u.role] = (counts[u.role] || 0) + 1; });
%>
<div class="users-stats">
  <div class="users-stat-card users-stat-card--admin">
    <div class="users-stat-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/>
      </svg>
    </div>
    <div>
      <div class="users-stat-value"><%= counts.admin %></div>
      <div class="users-stat-label">Администраторы</div>
    </div>
  </div>
  <div class="users-stat-card users-stat-card--storekeeper">
    <div class="users-stat-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      </svg>
    </div>
    <div>
      <div class="users-stat-value"><%= counts.storekeeper %></div>
      <div class="users-stat-label">Кладовщики</div>
    </div>
  </div>
  <div class="users-stat-card users-stat-card--user">
    <div class="users-stat-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
      </svg>
    </div>
    <div>
      <div class="users-stat-value"><%= counts.user %></div>
      <div class="users-stat-label">Пользователи</div>
    </div>
  </div>
  <div class="users-stat-card users-stat-card--total">
    <div class="users-stat-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    </div>
    <div>
      <div class="users-stat-value"><%= allUsers.length %></div>
      <div class="users-stat-label">Всего</div>
    </div>
  </div>
</div>

<!-- Toolbar -->
<div class="users-toolbar">
  <div class="users-toolbar__filters">
    <input type="text" id="users-search" placeholder="🔍 Поиск по логину..." class="users-search">
    <div class="seg-tabs">
      <a href="#" class="seg-tab active" data-role="all">Все</a>
      <a href="#" class="seg-tab" data-role="admin">Админы</a>
      <a href="#" class="seg-tab" data-role="storekeeper">Кладовщики</a>
      <a href="#" class="seg-tab" data-role="user">Пользователи</a>
    </div>
  </div>
  <button type="button" class="btn btn--primary" id="openAddUserBtn">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="8.5" cy="7" r="4"/>
      <line x1="20" y1="8" x2="20" y2="14"/>
      <line x1="23" y1="11" x2="17" y2="11"/>
    </svg>
    Добавить пользователя
  </button>
</div>

<!-- User cards grid -->
<div class="users-grid" id="usersGrid">
  <% allUsers.forEach(u => {
    const initials = u.username.slice(0, 2).toUpperCase();
    const canEdit = u.id !== user.id && !u.is_super_admin && (isSuperAdmin || u.role !== 'admin');
  %>
    <div class="user-card" data-role="<%= u.role %>" data-username="<%= u.username.toLowerCase() %>">
      <% if (u.is_super_admin) { %>
        <div class="user-card__crown" title="Главный администратор">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M5 16L3 7l5.5 5L12 4l3.5 8L21 7l-2 9H5zm14 3H5v2h14v-2z"/>
          </svg>
        </div>
      <% } %>
      <div class="user-card__header user-card__header--<%= u.role %>">
        <div class="user-card__avatar"><%= initials %></div>
        <div class="user-card__info">
          <div class="user-card__name">
            <%= u.username %>
            <% if (u.id === user.id) { %>
              <span class="self-badge">(вы)</span>
            <% } %>
          </div>
          <span class="role-badge role-badge--<%= u.role %>">
            <%= u.is_super_admin ? 'Главный админ' : roleLabels[u.role] %>
          </span>
        </div>
      </div>
      <div class="user-card__body">
        <div class="user-card__meta">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span>Создан: <%= new Date(u.created_at).toLocaleDateString('ru-RU') %></span>
        </div>
        <div class="user-card__meta">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>ID: <%= u.id %></span>
        </div>
      </div>
      <div class="user-card__actions">
        <% if (canEdit) { %>
          <form action="/admin/users/<%= u.id %>/role" method="POST" class="inline-form" style="flex: 1;">
            <select name="role" onchange="this.form.submit()" class="user-card__role-select">
              <% roles.forEach(r => {
                const isAdminOption = r === 'admin';
                const disabled = isAdminOption && !isSuperAdmin;
              %>
                <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %> <%= disabled ? 'disabled' : '' %>>
                  <%= roleLabels[r] %><%= disabled ? ' (только главный админ)' : '' %>
                </option>
              <% }) %>
            </select>
          </form>
          <form action="/admin/users/<%= u.id %>/delete" method="POST"
                onsubmit="return confirm('Удалить пользователя «<%= u.username %>»?')">
            <button type="submit" class="btn btn--sm btn--danger" title="Удалить">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
              </svg>
            </button>
          </form>
        <% } else if (u.is_super_admin && u.id !== user.id) { %>
          <div class="user-card__locked">🔒 Главный администратор</div>
        <% } else if (u.role === 'admin' && !isSuperAdmin && u.id !== user.id) { %>
          <div class="user-card__locked">🔒 Изменения недоступны</div>
        <% } else if (u.id === user.id) { %>
          <div class="user-card__locked">👤 Это вы</div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<div class="empty" id="emptyState" style="display: none;">
  <span class="empty-icon">🔍</span>
  <div style="font-weight: 600; font-size: 1.1rem; color: var(--gray-700); margin-bottom: 4px;">Никого не нашли</div>
  <div>Попробуйте изменить параметры поиска</div>
</div>

<!-- Модальное окно добавления пользователя -->
<div class="modal" id="addUserModal">
  <div class="modal-content">
    <div class="modal-header">
      <h2>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -5px; color: var(--green); margin-right: 6px;">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="8.5" cy="7" r="4"/>
          <line x1="20" y1="8" x2="20" y2="14"/>
          <line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
        Новый пользователь
      </h2>
      <button type="button" class="modal-close" id="closeAddUserModal">&times;</button>
    </div>
    <div class="modal-body">
      <form action="/admin/users" method="POST" class="user-form">
        <div class="form-row">
          <div class="form-group">
            <label for="username">Имя пользователя *</label>
            <input id="username" name="username" type="text" required placeholder="Логин">
          </div>
          <div class="form-group">
            <label for="password">Пароль *</label>
            <input id="password" name="password" type="password" required placeholder="Минимум 6 символов" minlength="6">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="first_name">Имя</label>
            <input id="first_name" name="first_name" type="text" placeholder="Иван">
          </div>
          <div class="form-group">
            <label for="last_name">Фамилия</label>
            <input id="last_name" name="last_name" type="text" placeholder="Иванов">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="gender">Пол</label>
            <select id="gender" name="gender">
              <option value="">Не указано</option>
              <option value="М">Мужской</option>
              <option value="Ж">Женский</option>
              <option value="Другое">Другое</option>
            </select>
          </div>
          <div class="form-group">
            <label for="phone">Телефон</label>
            <input id="phone" name="phone" type="tel" placeholder="+7 (999) 000-00-00">
          </div>
        </div>

        <div class="form-group">
          <label for="department">Отдел</label>
          <input id="department" name="department" type="text" placeholder="Отдел пользователя">
        </div>

        <div class="form-group">
          <label for="role">Роль *</label>
          <select id="role" name="role" required>
            <option value="user">Пользователь</option>
            <option value="storekeeper">Кладовщик</option>
            <option value="admin" <%= !isSuperAdmin ? 'disabled' : '' %>>
              Администратор<%= !isSuperAdmin ? ' (только главный админ)' : '' %>
            </option>
          </select>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn--primary btn--full">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Создать пользователя
          </button>
          <button type="button" class="btn btn--secondary btn--full" id="cancelAddUserBtn">Отмена</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  // Modal
  const addUserModal = document.getElementById('addUserModal');
  document.getElementById('openAddUserBtn').addEventListener('click', () => { addUserModal.style.display = 'block'; });
  document.getElementById('closeAddUserModal').addEventListener('click', () => { addUserModal.style.display = 'none'; });
  document.getElementById('cancelAddUserBtn').addEventListener('click', () => { addUserModal.style.display = 'none'; });
  window.addEventListener('click', (e) => { if (e.target === addUserModal) addUserModal.style.display = 'none'; });
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') addUserModal.style.display = 'none'; });

  // Filter & search
  const cards = document.querySelectorAll('.user-card');
  const emptyState = document.getElementById('emptyState');
  const tabs = document.querySelectorAll('.users-toolbar .seg-tab');
  const searchInput = document.getElementById('users-search');
  let activeRole = 'all';

  function applyFilter() {
    const q = searchInput.value.trim().toLowerCase();
    let visible = 0;
    cards.forEach(card => {
      const matchesRole = activeRole === 'all' || card.dataset.role === activeRole;
      const matchesSearch = !q || card.dataset.username.includes(q);
      const show = matchesRole && matchesSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    emptyState.style.display = visible === 0 ? '' : 'none';
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      activeRole = tab.dataset.role;
      applyFilter();
    });
  });

  searchInput.addEventListener('input', applyFilter);
</script>
