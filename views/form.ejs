<%- include('partials/header') %>

<div class="page-title">
  <a href="<%= tool ? '/tools/' + tool.id : '/' %>" class="back-link">← Назад</a>
  <h1><%= tool ? 'Редактировать: ' + tool.name : 'Новый инструмент' %></h1>
</div>

<% if (flash && flash.error) { %>
  <div class="alert alert--error">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <%= flash.error %>
  </div>
<% } %>

<form
  action="<%= tool ? '/tools/' + tool.id + '/update' : '/tools' %>"
  method="POST"
  class="form-card"
  enctype="multipart/form-data"
>
  <div class="form-group">
    <label for="name">Название *</label>
    <input id="name" name="name" type="text" required
           value="<%= tool ? tool.name : '' %>" placeholder="Например: Лопата штыковая">
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="category_id">Категория</label>
      <select id="category_id" name="category_id">
        <option value="">— Без категории —</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= tool && String(tool.category_id) === String(c.id) ? 'selected' : '' %>>
            <%= c.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="condition">Состояние *</label>
      <select id="condition" name="condition" required>
        <% conditions.forEach(cond => { %>
          <option value="<%= cond %>" <%= tool && tool.condition === cond ? 'selected' : (!tool && cond === 'хорошее' ? 'selected' : '') %>>
            <%= cond %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="quantity">Количество *</label>
      <input id="quantity" name="quantity" type="number" min="0" required
             value="<%= tool ? tool.quantity : 1 %>">
    </div>

    <div class="form-group">
      <label for="price">Стоимость (₽)</label>
      <input id="price" name="price" type="number" min="0" step="0.01"
             value="<%= tool && tool.price ? tool.price : '' %>" placeholder="0.00">
    </div>

    <div class="form-group">
      <label for="purchase_date">Дата покупки</label>
      <input id="purchase_date" name="purchase_date" type="date"
             value="<%= tool && tool.purchase_date ? new Date(tool.purchase_date).toISOString().split('T')[0] : '' %>">
    </div>
  </div>

  <div class="form-group">
    <label for="description">Описание</label>
    <textarea id="description" name="description" rows="3"
              placeholder="Краткое описание инструмента"><%= tool ? tool.description || '' : '' %></textarea>
  </div>

  <div class="form-group">
    <label>Фотографии</label>

    <% if (tool && tool.images && tool.images.length > 0) { %>
    <div class="existing-images">
      <p class="hint">Существующие фотографии (перетащи для переупорядочивания)</p>
      <div id="existingImagesPreview" class="images-preview">
        <% tool.images.forEach((img, idx) => { %>
          <div class="image-preview-item existing-image" draggable="true" data-image-id="<%= img.id %>" data-index="<%= idx %>">
            <img src="/uploads/<%= img.filename %>" alt="Фото <%= idx + 1 %>">
            <button type="button" class="image-preview-remove delete-existing" data-image-id="<%= img.id %>">×</button>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <p class="hint">Выберите одно или несколько новых изображений для добавления</p>
    <div class="image-upload-area">
      <input id="images" name="images" type="file" accept=".jpg,.jpeg,.png,.webp" multiple class="file-input-images">
      <div class="upload-prompt">
        <span class="upload-icon">📸</span>
        <p>Нажми для выбора файлов или перетащи сюда</p>
      </div>
    </div>
    <div id="imagesPreview" class="images-preview"></div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn--primary">
      <%= tool ? 'Сохранить изменения' : 'Добавить' %>
    </button>
    <a href="<%= tool ? '/tools/' + tool.id : '/' %>" class="btn">Отмена</a>
  </div>
</form>

<%- include('partials/footer') %>
